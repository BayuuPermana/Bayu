{
  "name": "gemini-live-commentator",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --hot packages/api/src/index.ts",
    "dev:web": "cd packages/web && bun run vite",
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "test:api": "cd packages/api && bun test",
    "test:python": "cd python && venv/Scripts/python src/test_integration.py",
    "test:all": "bun run test:api && bun run test:python",
    "install:all": "bun install && cd packages/api && bun install && cd ../web && bun install"
  },
  "devDependencies": {
    "bun-types": "latest",
    "concurrently": "^9.2.1"
  }
}
